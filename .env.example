# Local AI (offline)
#REALTIME_AI_PROVIDER=local
#OLLAMA_MODEL=llama3.2:latest
# Use a model already under ~/.cache/huggingface/hub/ (e.g. base, small, small.en)
#WHISPER_MODEL=base
#HF_HOME=/home/billy/.cache/huggingface
# Do not set HF_HUB_OFFLINE=1 — it breaks Whisper cache lookup even when models exist.
# Piper TTS — run ./setup/preload_piper.sh once while online
#TTS_VOICE=en_US-lessac-medium
#PIPER_MODEL_DIR=/home/billy/.piper/models
#TTS_VOCAL_PROCESSING=true
#TTS_VOCAL_DARKEN=0.35
#TTS_VOCAL_DRIVE=0.18
#TTS_VOCAL_LOWPASS_HZ=4200

# Billy GPIO (see docs/BUILDME.md): new = default wall mount, legacy = pre-Oct 2025
#BILLY_PINS=new
#BILLY_MODEL=modern
# Override BCM pin numbers if motors are on different GPIOs (uncomment and set):
#MOTOR_HEAD_GPIO=22
#MOTOR_MOUTH_GPIO=17
#MOTOR_TAIL_GPIO=27
#FLAP_ON_BOOT=true
#MOUTH_FLAP_THRESHOLD=80
#INVERT_HEAD_MOUTH=false
#MOTOR_REVERSE_ALL=true

#SPEAKER_PREFERENCE=UACDemo

# Audio (USB on Pi)
#CHUNK_MS=100
#PLAYBACK_LATENCY=0.5
#USE_APLAY=false
